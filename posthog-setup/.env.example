# PostHog — Product analytics
#
# Récupère ta Project API Key sur https://eu.posthog.com (instance EU, RGPD).
# La même clé fonctionne en dev et en prod (PostHog différencie via les events).
#
# Côté frontend (Vite, expose VITE_ prefix) :
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Mettre à true pour voir les events en console en dev (sans les envoyer à PostHog)
# Laisser false ou supprimer en prod
VITE_POSTHOG_DEBUG=false

# Côté serveur (pour le webhook Stripe → subscription_active) :
# Crée une clé personal ou utilise la project API key
POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://eu.i.posthog.com
